# evo-memory — environment configuration
# Copy to .env and edit:  cp .env.example .env

# ── Required ──────────────────────────────────────────────────────────────────
# HuggingFace model ID or local path to the base model.
LLM_MODEL_PATH=meta-llama/Llama-3.2-1B-Instruct

# ── Optional ──────────────────────────────────────────────────────────────────
# Where HuggingFace caches model weights (default: <repo>/.hf_cache).
# HF_CACHE_DIR=/path/to/hf/cache

# GPU index (default: 0). Set via `make setup-gpu GPU=N` or manually here.
# CUDA_VISIBLE_DEVICES=0

# ── Evaluation ────────────────────────────────────────────────────────────────
# Path to a trained NAMM checkpoint (only needed for eval / ES+NAMM runs).
# NAMM_CKPT=exp_local/pretrained/namm.pt

# ── Experiment tracking ──────────────────────────────────────────────────────
# Weights & Biases API key (only needed when wandb_log=true).
# WANDB_API_KEY=your_key_here

# ── Cloud (TPU / GCS experiments) ────────────────────────────────────────────
# GCS_BUCKET=statistical-nlp
# GCS_PROJECT=statistical-nlp
