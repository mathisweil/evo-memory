# ─── evo-memory environment variables ─────────────────────────────────────────
# Copy this file to .env and fill in the values for your environment.
# Never commit .env to version control.
# ──────────────────────────────────────────────────────────────────────────────

# ── Model ─────────────────────────────────────────────────────────────────────

# Path to the Llama-3.2-1B-Instruct model.
# Can be either a local snapshot directory or a HuggingFace model ID.
#   Local:   LLM_MODEL_PATH=/data/models/llama-1b-instruct-hf
#   Remote:  LLM_MODEL_PATH=meta-llama/Llama-3.2-1B-Instruct
LLM_MODEL_PATH=meta-llama/Llama-3.2-1B-Instruct

# Directory where HuggingFace datasets and models are cached.
# Defaults to ~/.cache/huggingface if unset.
HF_CACHE_DIR=/cs/student/project_msc/2025/dsml/mathweil/huggingface

# ── Checkpoints ───────────────────────────────────────────────────────────────

# Path to a trained NAMM checkpoint (required for eval scripts).
# Set before running run_namm_instruct_eval.sh or rh_instruct_namm_eval config.
# NAMM_CKPT=/path/to/exp_local/memory_evolution_hf/.../ckpt.pt

# ── Hardware ──────────────────────────────────────────────────────────────────

# Which CUDA GPU(s) to use. Comma-separate for multi-GPU (e.g. "0,1").
# Defaults to GPU 0 if unset.
CUDA_VISIBLE_DEVICES=1

# ── Weights & Biases ──────────────────────────────────────────────────────────

# WandB API key — only needed if wandb_log=true in config.
# WANDB_API_KEY=your_wandb_api_key_here

# ── Google Cloud Storage (TPU / cloud experiments only) ───────────────────────

# GCS bucket that stores experiments, checkpoints, and the XLA cache.
# Only required when running with --gcs or on TPU.
GCS_BUCKET=statistical-nlp

# GCS project ID associated with the bucket.
GCS_PROJECT=statistical-nlp
